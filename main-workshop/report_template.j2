Nuitka: {{ nuitka_version }}
Python: {{ python_version }} ({{ python_flavor }})
OS: {{ os_name }} {{ os_release }} / {{ arch_name }}
Mode: {{ compilation_mode }}

{% set timing_data = [] %}
{% for name in module_names %}
{% set passes = module_timing_infos.get(name, []) %}
{% set pass1 = namespace(t=0.0) %}
{% set pass2 = namespace(t=0.0) %}
{% for p in passes %}
{% if p.pass_number == 1 %}{% set pass1.t = p.time_used | float %}{% endif %}
{% if p.pass_number == 2 %}{% set pass2.t = p.time_used | float %}{% endif %}
{% endfor %}
{% set total = pass1.t + pass2.t %}
{% if total > 0 %}
{% set _ = timing_data.append((name, pass1.t, pass2.t, total)) %}
{% endif %}
{% endfor %}

{% set sorted_timing = timing_data | sort(attribute=3, reverse=True) %}

{# ---- aggregate by top-level package ---- #}
{% set top_pkg = namespace(data={}) %}
{% for name, p1, p2, total in sorted_timing %}
{% set pkg = name.getTopLevelPackageName() %}
{% if pkg in top_pkg.data %}
{% set _ = top_pkg.data.update({pkg: top_pkg.data[pkg] + total}) %}
{% else %}
{% set _ = top_pkg.data.update({pkg: total}) %}
{% endif %}
{% endfor %}
{% set top_pkg_list = top_pkg.data.items() | list | sort(attribute=1, reverse=True) %}

{{ top_pkg_list | length }} packages
{{ "-" * 50 }}
{{ "%-38s" | format("Package") }} {{ "%10s" | format("Total(s)") }} {{ "%8s" | format("Share") }}
{{ "-" * 50 }}
{% set grand = sorted_timing | sum(attribute=3) %}
{% for pkg, t in top_pkg_list %}
{{ "%-38s" | format(pkg) }} {{ "%10.3f" | format(t) }} {{ "%7.1f" | format(t / grand * 100) }}%
{% endfor %}
{{ "-" * 50 }}
{{ "%-38s" | format("Total") }} {{ "%10.3f" | format(grand) }}

